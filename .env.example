# Copy this to .env.local for local dev (Vercel dev).
# In production, set these in Vercel → Settings → Environment Variables.

# Neon Postgres connection string
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

# Admin login password (plain text; only used on server)
ADMIN_PASSWORD=change-me

# Random long string used to sign admin cookies. 32+ chars recommended.
ADMIN_COOKIE_SECRET=replace-with-random-string

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxx
MAIL_TO=your@email.com
MAIL_FROM=SKR <onboarding@resend.dev>

# Vercel Blob (auto-injected on Vercel when Blob is connected; only set locally)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
